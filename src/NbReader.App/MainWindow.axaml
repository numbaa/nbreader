<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:NbReader.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NbReader.App.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
        x:CompileBindings="False"
        MinWidth="960"
        MinHeight="640"
        Width="1280"
        Height="800"
        Title="NbReader">
    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*,Auto">
        <Border Grid.RowSpan="3"
                Background="#111827"
                Padding="20">
            <StackPanel Spacing="18">
                <TextBlock Text="NbReader"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F9FAFB" />
                <TextBlock Text="本地漫画库"
                           FontSize="13"
                           Foreground="#93C5FD" />

                <StackPanel Spacing="8">
                    <TextBlock Text="模块"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E5E7EB">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="#1F2937"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="24,20"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="24">
            <Border IsVisible="{Binding IsCatalogSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                                <Grid RowDefinitions="Auto,Auto,*"
                                            ColumnDefinitions="2*,3*"
                                            ColumnSpacing="16"
                                            RowSpacing="12">
                    <TextBlock Text="系列卡片"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusMessage}"
                               Foreground="#334155"
                               TextWrapping="Wrap" />

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            IsVisible="{Binding IsCatalogEmpty}"
                            Background="#FFF7ED"
                            BorderBrush="#FDBA74"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="书架暂无数据"
                                       FontWeight="SemiBold"
                                       Foreground="#9A3412" />
                            <TextBlock Text="请先导入一个目录或 zip，然后返回 Catalog 查看系列。"
                                       Foreground="#9A3412"
                                       TextWrapping="Wrap" />
                            <Button Content="去 Import"
                                    HorizontalAlignment="Left"
                                    Click="OnCatalogGoToImportClick" />
                        </StackPanel>
                    </Border>

                                        <ListBox Grid.Row="2"
                             Grid.Column="0"
                             ItemsSource="{Binding SeriesCards}"
                             SelectedItem="{Binding SelectedSeries, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SeriesCardViewModel">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VolumeCount, StringFormat='卷数：{0}'}"
                                                   Foreground="#475569" />
                                        <TextBlock Text="{Binding LatestUpdatedText, StringFormat='最近更新：{0}'}"
                                                   Foreground="#64748B"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                                                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,*"
                              RowSpacing="10">
                            <TextBlock Text="系列详情"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SeriesDetailTitle}"
                                       Foreground="#475569"
                                       TextWrapping="Wrap" />

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding VolumeCards}"
                                     SelectedItem="{Binding SelectedVolume, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:VolumeCardViewModel">
                                        <Border BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding PageCount, StringFormat='页数：{0}'}"
                                                           Foreground="#64748B" />
                                                <TextBlock Text="{Binding VolumeNumberText, StringFormat='卷号：{0}'}"
                                                           Foreground="#64748B" />
                                                <TextBlock Text="{Binding CreatedAtText, StringFormat='导入时间：{0}'}"
                                                           FontSize="12"
                                                           Foreground="#94A3B8" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="打开所选卷"
                                        IsEnabled="{Binding CanOpenSelectedVolume}"
                                        Click="OnOpenSelectedVolumeClick" />
                                <Button Content="继续阅读"
                                        IsEnabled="{Binding CanContinueReading}"
                                        Click="OnOpenContinueReadingClick" />
                                <TextBlock Text="{Binding IsLoadingVolumes, StringFormat='加载卷中：{0}'}"
                                           VerticalAlignment="Center"
                                           Foreground="#64748B" />
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Spacing="4">
                                <TextBlock Text="{Binding CatalogPrimaryActionHint}"
                                           Foreground="#92400E"
                                           IsVisible="{Binding ShouldShowCatalogPrimaryActionHint}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ContinueReadingActionHint}"
                                           Foreground="#92400E"
                                           IsVisible="{Binding ShouldShowContinueReadingActionHint}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="5"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid RowDefinitions="Auto,Auto,*,Auto"
                                      RowSpacing="8">
                                    <TextBlock Text="最近阅读"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding ContinueReadingSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="#475569" />
                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding RecentReadings}"
                                             SelectedItem="{Binding SelectedRecentReading, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:RecentReadingItemViewModel">
                                                <Border BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="8"
                                                        Margin="0,0,0,6">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding SeriesTitle}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding VolumeTitle}" />
                                                        <TextBlock Text="{Binding CurrentPageText, StringFormat='进度：{0}'}"
                                                                   Foreground="#64748B" />
                                                        <TextBlock Text="{Binding LastReadAtText, StringFormat='最近阅读：{0}'}"
                                                                   FontSize="12"
                                                                   Foreground="#94A3B8" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Button Grid.Row="3"
                                            Content="打开所选最近记录"
                                            IsEnabled="{Binding CanOpenSelectedRecentReading}"
                                            Click="OnOpenSelectedRecentReadingClick" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

                <Border IsVisible="{Binding IsImportSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
                      RowSpacing="10">
                    <TextBlock Text="导入"
                           FontSize="20"
                           FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                           Text="输入本地 zip 文件或图片目录路径，先分析再执行导入。"
                           Foreground="#475569"
                           TextWrapping="Wrap" />

                    <ComboBox Grid.Row="2"
                              ItemsSource="{Binding RecentImportPaths}"
                              SelectedItem="{Binding SelectedRecentImportPath, Mode=TwoWay}" />

                                        <Grid Grid.Row="3"
                                            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                                            ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                         Text="{Binding ImportPathInput, Mode=TwoWay}"
                                 PlaceholderText="例如：D:\\Comics\\OnePiece 或 D:\\Comics\\Vol01.zip" />
                    <Button Grid.Column="1"
                                                Content="选目录"
                                                Click="OnImportPickFolderClick" />
                                        <Button Grid.Column="2"
                                                Content="选 zip"
                                                Click="OnImportPickZipClick" />
                                        <Button Grid.Column="3"
                        Content="分析输入"
                        IsEnabled="{Binding CanAnalyzeImportInput}"
                        Click="OnImportAnalyzeClick" />
                                        <Button Grid.Column="4"
                        Content="执行导入"
                        IsEnabled="{Binding CanExecuteImport}"
                        Click="OnImportExecuteClick" />
                    </Grid>

                    <Border Grid.Row="4"
                        Background="#FFFFFF"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="8">
                        <TextBlock Text="{Binding ImportInputKindSummary}"
                               Grid.ColumnSpan="2" />
                        <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding ImportPlanSummary}"
                               TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                               Text="{Binding ImportWarningsSummary, StringFormat='告警：{0}'}"
                               Foreground="#92400E"
                               TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding ImportConflictsSummary, StringFormat='冲突：{0}'}"
                               Foreground="#B91C1C"
                               TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3"
                               Grid.ColumnSpan="2"
                               Text="{Binding ImportExecutionSummary}"
                               Foreground="#334155"
                               TextWrapping="Wrap" />
                    </Grid>
                    </Border>

                    <Border Grid.Row="5"
                        IsVisible="{Binding ImportRequiresConfirmation}"
                        Background="#FFF7ED"
                        BorderBrush="#FDBA74"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="*"
                          RowSpacing="8">
                        <TextBlock Text="检测到需确认的导入计划，将在执行导入时应用以下策略。"
                               Foreground="#9A3412"
                               TextWrapping="Wrap" />
                        <TextBox Grid.Row="1"
                             Text="{Binding ImportSeriesNameOverride, Mode=TwoWay}"
                                     PlaceholderText="系列名覆盖（可选）" />
                        <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="14">
                        <CheckBox Content="跳过重复卷号"
                              IsChecked="{Binding ImportSkipDuplicateVolumes, Mode=TwoWay}" />
                        <CheckBox Content="忽略告警"
                              IsChecked="{Binding ImportIgnoreWarnings, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                    </Border>

                          <TextBlock Grid.Row="6"
                           Text="{Binding StatusMessage}"
                           Foreground="#334155"
                           TextWrapping="Wrap" />

                          <TextBlock Grid.Row="7"
                           Text="导入完成后会自动刷新 Catalog，并同步搜索整理工作台。"
                           Foreground="#64748B"
                           TextWrapping="Wrap" />
                </Grid>
                </Border>

            <Border IsVisible="{Binding IsReaderSection}"
                    Background="#F1F5F9"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="阅读器"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ReaderLaunchSummary}"
                               TextWrapping="Wrap"
                               Foreground="#334155" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="12">
                        <TextBlock Text="{Binding ReaderPageIndicator, StringFormat='页码：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderStateLabel, StringFormat='状态：{0}'}"
                                   Foreground="#475569"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderDisplayModeLabel, StringFormat='模式：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderDirectionLabel, StringFormat='方向：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <Button Content="切换单双页"
                                Click="OnReaderToggleModeClick" />
                        <Button Content="切换方向"
                                Click="OnReaderToggleDirectionClick" />
                        <Button Content="上一页"
                                IsEnabled="{Binding CanGoToPreviousPage}"
                                Click="OnReaderPreviousPageClick" />
                        <Button Content="下一页"
                                IsEnabled="{Binding CanGoToNextPage}"
                                Click="OnReaderNextPageClick" />
                    </StackPanel>
                    <Border Height="520"
                            Background="#0B1220"
                            CornerRadius="8"
                            Padding="8"
                            IsVisible="{Binding IsSinglePageMode}">
                        <Image Source="{Binding ReaderPreviewImage}"
                               Stretch="Uniform" />
                    </Border>
                    <Border Height="520"
                            Background="#0B1220"
                            CornerRadius="8"
                            Padding="8"
                            IsVisible="{Binding IsDualPageMode}">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2"
                                    IsVisible="{Binding HasReaderLeftPageImage}">
                                <Image Source="{Binding ReaderLeftPageImage}"
                                       Stretch="Uniform" />
                            </Border>
                            <Border Grid.Column="1"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2"
                                    IsVisible="{Binding HasReaderRightPageImage}">
                                <Image Source="{Binding ReaderRightPageImage}"
                                       Stretch="Uniform" />
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="预加载策略：以当前显示页为中心，保留邻近 1 页；双页模式会同时覆盖左右页。"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsSearchSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                      RowSpacing="10">
                                                    <TextBlock Text="搜索与整理"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding SearchWorkspaceSummary}"
                               Foreground="#475569"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Content="刷新视图"
                                Click="OnSearchRefreshClick" />
                        <Button Content="重新处理所选失败任务"
                                IsEnabled="{Binding CanRetrySelectedFailedImportTask}"
                                Click="OnSearchRetryFailedTaskClick" />
                        <TextBlock Text="{Binding IsLoadingSearchWorkspace, StringFormat='加载中：{0}'}"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B" />
                    </StackPanel>

                    <Border Grid.Row="3"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0"
                                        Spacing="6">
                                <TextBlock Text="系列改名"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="当前选中 Catalog 中的系列。"
                                           Foreground="#64748B"
                                           FontSize="12" />
                                <TextBox Text="{Binding SeriesRenameInput, Mode=TwoWay}" />
                                <Button Content="应用改名"
                                        IsEnabled="{Binding CanApplySeriesRename}"
                                        Click="OnSearchApplySeriesRenameClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="系列合并"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="将当前选中系列合并到目标系列。"
                                           Foreground="#64748B"
                                           FontSize="12" />
                                <ComboBox ItemsSource="{Binding MergeTargetSeriesOptions}"
                                          SelectedItem="{Binding SelectedMergeTargetSeries, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:SeriesMergeTargetItemViewModel">
                                            <TextBlock Text="{Binding DisplayText}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Content="执行合并"
                                        IsEnabled="{Binding CanMergeSelectedSeries}"
                                        Click="OnSearchMergeSeriesClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="6">
                                <TextBlock Text="卷号修正"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="当前选中 Catalog 中的卷，留空可清除卷号。"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <TextBox Text="{Binding VolumeNumberInput, Mode=TwoWay}"
                                     PlaceholderText="例如 1" />
                                <Button Content="应用卷号"
                                        IsEnabled="{Binding CanApplyVolumeNumberCorrection}"
                                        Click="OnSearchApplyVolumeNumberClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="6">
                                <TextBlock Text="作者与标签编辑"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="编辑当前选中系列，使用逗号分隔。"
                                           Foreground="#64748B"
                                           FontSize="12" />
                                <TextBox Text="{Binding AuthorNamesInput, Mode=TwoWay}"
                                         PlaceholderText="作者1, 作者2" />
                                <TextBox Text="{Binding TagNamesInput, Mode=TwoWay}"
                                         PlaceholderText="标签1, 标签2" />
                                <Button Content="应用作者/标签"
                                        IsEnabled="{Binding CanApplySeriesMetadata}"
                                        Click="OnSearchApplySeriesMetadataClick" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">
                                <TextBlock Text="未整理卷"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding UnorganizedVolumes}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:UnorganizedVolumeItemViewModel">
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding VolumeTitle}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SourcePath}"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding CreatedAtText, StringFormat='导入时间：{0}'}"
                                                               FontSize="12"
                                                               Foreground="#94A3B8" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">
                                <TextBlock Text="导入失败任务"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding FailedImportTasks}"
                                         SelectedItem="{Binding SelectedFailedImportTask, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:FailedImportTaskItemViewModel">
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding RawInput}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ErrorText, StringFormat='错误：{0}'}"
                                                               Foreground="#B91C1C"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Status, StringFormat='状态：{0}'}"
                                                               Foreground="#64748B" />
                                                    <TextBlock Text="{Binding UpdatedAtText, StringFormat='更新时间：{0}'}"
                                                               FontSize="12"
                                                               Foreground="#94A3B8" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding RuntimeSummary}"
                           Foreground="#475569" />
                <Expander Header="诊断信息"
                          IsExpanded="{Binding IsDiagnosticsExpanded, Mode=TwoWay}">
                    <TextBlock Text="{Binding DiagnosticsText}"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
