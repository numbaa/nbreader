<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:NbReader.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NbReader.App.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
        x:CompileBindings="False"
        MinWidth="960"
        MinHeight="640"
        Width="1280"
        Height="800"
        Title="NbReader">
    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*,Auto">
        <Border Grid.RowSpan="3"
                Background="#111827"
                Padding="20">
            <StackPanel Spacing="18">
                <TextBlock Text="NbReader"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F9FAFB" />
                <TextBlock Text="Phase 2 M2"
                           FontSize="13"
                           Foreground="#93C5FD" />

                <StackPanel Spacing="8">
                    <TextBlock Text="模块"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E5E7EB">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="#1F2937"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="24,20"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding CurrentSection, StringFormat='当前区域：{0}'}"
                           Foreground="#334155"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="24">
            <Border IsVisible="{Binding IsCatalogSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                                <Grid RowDefinitions="Auto,Auto,*"
                                            ColumnDefinitions="2*,3*"
                                            ColumnSpacing="16"
                                            RowSpacing="12">
                    <TextBlock Text="系列卡片"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusMessage}"
                               Foreground="#334155"
                               TextWrapping="Wrap" />

                                        <ListBox Grid.Row="2"
                                                         Grid.Column="0"
                             ItemsSource="{Binding SeriesCards}"
                             SelectedItem="{Binding SelectedSeries, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SeriesCardViewModel">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VolumeCount, StringFormat='卷数：{0}'}"
                                                   Foreground="#475569" />
                                        <TextBlock Text="{Binding LatestUpdatedText, StringFormat='最近更新：{0}'}"
                                                   Foreground="#64748B"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                                                <Grid RowDefinitions="Auto,Auto,*,Auto,*"
                              RowSpacing="10">
                            <TextBlock Text="系列详情"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SeriesDetailTitle}"
                                       Foreground="#475569"
                                       TextWrapping="Wrap" />

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding VolumeCards}"
                                     SelectedItem="{Binding SelectedVolume, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:VolumeCardViewModel">
                                        <Border BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding PageCount, StringFormat='页数：{0}'}"
                                                           Foreground="#64748B" />
                                                <TextBlock Text="{Binding CreatedAtText, StringFormat='导入时间：{0}'}"
                                                           FontSize="12"
                                                           Foreground="#94A3B8" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="打开所选卷"
                                        IsEnabled="{Binding CanOpenSelectedVolume}"
                                        Click="OnOpenSelectedVolumeClick" />
                                <Button Content="继续阅读"
                                        IsEnabled="{Binding CanContinueReading}"
                                        Click="OnOpenContinueReadingClick" />
                                <TextBlock Text="{Binding IsLoadingVolumes, StringFormat='加载卷中：{0}'}"
                                           VerticalAlignment="Center"
                                           Foreground="#64748B" />
                            </StackPanel>

                            <Border Grid.Row="4"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid RowDefinitions="Auto,Auto,*,Auto"
                                      RowSpacing="8">
                                    <TextBlock Text="最近阅读"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding ContinueReadingSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="#475569" />
                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding RecentReadings}"
                                             SelectedItem="{Binding SelectedRecentReading, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:RecentReadingItemViewModel">
                                                <Border BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="8"
                                                        Margin="0,0,0,6">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding SeriesTitle}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding VolumeTitle}" />
                                                        <TextBlock Text="{Binding CurrentPageText, StringFormat='进度：{0}'}"
                                                                   Foreground="#64748B" />
                                                        <TextBlock Text="{Binding LastReadAtText, StringFormat='最近阅读：{0}'}"
                                                                   FontSize="12"
                                                                   Foreground="#94A3B8" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Button Grid.Row="3"
                                            Content="打开所选最近记录"
                                            IsEnabled="{Binding CanOpenSelectedRecentReading}"
                                            Click="OnOpenSelectedRecentReadingClick" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border IsVisible="{Binding IsReaderSection}"
                    Background="#F1F5F9"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reader 阅读（M4）"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ReaderLaunchSummary}"
                               TextWrapping="Wrap"
                               Foreground="#334155" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="12">
                        <TextBlock Text="{Binding ReaderPageIndicator, StringFormat='页码：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderStateLabel, StringFormat='状态：{0}'}"
                                   Foreground="#475569"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderDisplayModeLabel, StringFormat='模式：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReaderDirectionLabel, StringFormat='方向：{0}'}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center" />
                        <Button Content="切换单双页"
                                Click="OnReaderToggleModeClick" />
                        <Button Content="切换方向"
                                Click="OnReaderToggleDirectionClick" />
                        <Button Content="上一页"
                                IsEnabled="{Binding CanGoToPreviousPage}"
                                Click="OnReaderPreviousPageClick" />
                        <Button Content="下一页"
                                IsEnabled="{Binding CanGoToNextPage}"
                                Click="OnReaderNextPageClick" />
                    </StackPanel>
                    <Border Height="520"
                            Background="#0B1220"
                            CornerRadius="8"
                            Padding="8"
                            IsVisible="{Binding IsSinglePageMode}">
                        <Image Source="{Binding ReaderPreviewImage}"
                               Stretch="Uniform" />
                    </Border>
                    <Border Height="520"
                            Background="#0B1220"
                            CornerRadius="8"
                            Padding="8"
                            IsVisible="{Binding IsDualPageMode}">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2"
                                    IsVisible="{Binding HasReaderLeftPageImage}">
                                <Image Source="{Binding ReaderLeftPageImage}"
                                       Stretch="Uniform" />
                            </Border>
                            <Border Grid.Column="1"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2"
                                    IsVisible="{Binding HasReaderRightPageImage}">
                                <Image Source="{Binding ReaderRightPageImage}"
                                       Stretch="Uniform" />
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="预加载策略：以当前显示页为中心，保留邻近 1 页；双页模式会同时覆盖左右页。"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsSearchSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <Grid RowDefinitions="Auto,Auto,Auto,*"
                      RowSpacing="10">
                    <TextBlock Text="搜索整理工作台（M3）"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding SearchWorkspaceSummary}"
                               Foreground="#475569"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Content="刷新视图"
                                Click="OnSearchRefreshClick" />
                        <Button Content="重新处理所选失败任务"
                                IsEnabled="{Binding CanRetrySelectedFailedImportTask}"
                                Click="OnSearchRetryFailedTaskClick" />
                        <TextBlock Text="{Binding IsLoadingSearchWorkspace, StringFormat='加载中：{0}'}"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B" />
                    </StackPanel>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">
                                <TextBlock Text="未整理卷"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding UnorganizedVolumes}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:UnorganizedVolumeItemViewModel">
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding VolumeTitle}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SourcePath}"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding CreatedAtText, StringFormat='导入时间：{0}'}"
                                                               FontSize="12"
                                                               Foreground="#94A3B8" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">
                                <TextBlock Text="导入失败任务"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding FailedImportTasks}"
                                         SelectedItem="{Binding SelectedFailedImportTask, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:FailedImportTaskItemViewModel">
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding RawInput}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ErrorText, StringFormat='错误：{0}'}"
                                                               Foreground="#B91C1C"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Status, StringFormat='状态：{0}'}"
                                                               Foreground="#64748B" />
                                                    <TextBlock Text="{Binding UpdatedAtText, StringFormat='更新时间：{0}'}"
                                                               FontSize="12"
                                                               Foreground="#94A3B8" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border IsVisible="{Binding IsPlaceholderSection}"
                    Background="#FFF7ED"
                    BorderBrush="#FDBA74"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="功能预留"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="当前阶段先实现 Catalog。其余模块将在后续里程碑逐步落地。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#9A3412"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <TextBlock Text="{Binding Footer}"
                       Foreground="#475569" />
        </Border>
    </Grid>
</Window>
