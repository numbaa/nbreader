<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:NbReader.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NbReader.App.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
        x:CompileBindings="False"
        MinWidth="960"
        MinHeight="640"
        Width="1280"
        Height="800"
        Title="NbReader">
    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*,Auto">
        <Border Grid.RowSpan="3"
                Background="#111827"
                Padding="20">
            <StackPanel Spacing="18">
                <TextBlock Text="NbReader"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F9FAFB" />
                <TextBlock Text="Phase 2 M2"
                           FontSize="13"
                           Foreground="#93C5FD" />

                <StackPanel Spacing="8">
                    <TextBlock Text="模块"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E5E7EB">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="#1F2937"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="24,20"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding CurrentSection, StringFormat='当前区域：{0}'}"
                           Foreground="#334155"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="24">
            <Border IsVisible="{Binding IsCatalogSection}"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                                <Grid RowDefinitions="Auto,Auto,*"
                                            ColumnDefinitions="2*,3*"
                                            ColumnSpacing="16"
                                            RowSpacing="12">
                    <TextBlock Text="系列卡片"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusMessage}"
                               Foreground="#334155"
                               TextWrapping="Wrap" />

                                        <ListBox Grid.Row="2"
                                                         Grid.Column="0"
                             ItemsSource="{Binding SeriesCards}"
                             SelectedItem="{Binding SelectedSeries, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SeriesCardViewModel">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VolumeCount, StringFormat='卷数：{0}'}"
                                                   Foreground="#475569" />
                                        <TextBlock Text="{Binding LatestUpdatedText, StringFormat='最近更新：{0}'}"
                                                   Foreground="#64748B"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <Grid RowDefinitions="Auto,Auto,*,Auto"
                              RowSpacing="10">
                            <TextBlock Text="系列详情"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SeriesDetailTitle}"
                                       Foreground="#475569"
                                       TextWrapping="Wrap" />

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding VolumeCards}"
                                     SelectedItem="{Binding SelectedVolume, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:VolumeCardViewModel">
                                        <Border BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding PageCount, StringFormat='页数：{0}'}"
                                                           Foreground="#64748B" />
                                                <TextBlock Text="{Binding CreatedAtText, StringFormat='导入时间：{0}'}"
                                                           FontSize="12"
                                                           Foreground="#94A3B8" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="打开所选卷"
                                        IsEnabled="{Binding CanOpenSelectedVolume}"
                                        Click="OnOpenSelectedVolumeClick" />
                                <TextBlock Text="{Binding IsLoadingVolumes, StringFormat='加载卷中：{0}'}"
                                           VerticalAlignment="Center"
                                           Foreground="#64748B" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border IsVisible="{Binding IsReaderSection}"
                    Background="#F1F5F9"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reader 入口（M2 占位）"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ReaderLaunchSummary}"
                               TextWrapping="Wrap"
                               Foreground="#334155" />
                    <Border Height="520"
                            Background="#0B1220"
                            CornerRadius="8"
                            Padding="8">
                        <Image Source="{Binding ReaderPreviewImage}"
                               Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="下一步将接入统一页源与阅读状态。"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsPlaceholderSection}"
                    Background="#FFF7ED"
                    BorderBrush="#FDBA74"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="功能预留"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="当前阶段先实现 Catalog。其余模块将在后续里程碑逐步落地。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#9A3412"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <TextBlock Text="{Binding Footer}"
                       Foreground="#475569" />
        </Border>
    </Grid>
</Window>
