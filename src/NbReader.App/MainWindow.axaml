<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:NbReader.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NbReader.App.MainWindow"
        x:CompileBindings="False"
        MinWidth="960"
        MinHeight="640"
        Width="1280"
        Height="800"
        Title="NbReader">
    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*,Auto">
        <Border Grid.RowSpan="3"
                Background="#111827"
                Padding="20">
            <StackPanel Spacing="18">
                <TextBlock Text="NbReader"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F9FAFB" />
                <TextBlock Text="Phase 0 骨架"
                           FontSize="13"
                           Foreground="#93C5FD" />

                <StackPanel Spacing="8">
                    <TextBlock Text="模块"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB" />
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1F2937"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#E5E7EB" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="24,20"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              ColumnDefinitions="3*,2*"
              Margin="24">
            <Border Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,16,0">
                <StackPanel Spacing="16">
                    <TextBlock Text="Phase 0 验证控制台"
                               FontSize="20"
                               FontWeight="SemiBold" />

                    <WrapPanel ItemWidth="160"
                               ItemHeight="38"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top">
                        <Button Content="选择图片目录"
                                Width="152"
                                Click="OnPickDirectoryClick" />
                        <Button Content="选择 zip 文件"
                                Width="152"
                                Margin="12,0,0,0"
                                Click="OnPickZipClick" />
                    </WrapPanel>

                    <TextBlock x:Name="ActionStatusText"
                               Text="等待操作。"
                               Foreground="#0F172A"
                               TextWrapping="Wrap" />

                    <Border Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="目录首图预览"
                                       FontWeight="SemiBold" />
                            <Border Height="360"
                                    Background="#0B1220"
                                    CornerRadius="8"
                                    Padding="8">
                                <Image x:Name="PreviewImage"
                                       Stretch="Uniform" />
                            </Border>
                            <TextBlock x:Name="DirectorySummaryText"
                                       Text="尚未选择目录。"
                                       TextWrapping="Wrap"
                                       Foreground="#334155" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFBEB"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="下一个里程碑"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding NextMilestone}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="zip 枚举结果"
                               Margin="0,8,0,0"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ZipSummaryText"
                               Text="尚未选择 zip。"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DatabaseSummaryText"
                               Text="数据库写入状态：未执行。"
                               TextWrapping="Wrap"
                               Foreground="#92400E" />
                    <TextBlock Text="运行时状态"
                               Margin="0,8,0,0"
                               FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding RuntimeChecks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='• {0}'}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding EnvironmentSummary}"
                               TextWrapping="Wrap"
                               Foreground="#92400E" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <TextBlock Text="{Binding Footer}"
                       Foreground="#475569" />
        </Border>
    </Grid>
</Window>
