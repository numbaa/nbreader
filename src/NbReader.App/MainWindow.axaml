<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:NbReader.App.ViewModels"
        xmlns:views="using:NbReader.App.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NbReader.App.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        x:CompileBindings="False"
        MinWidth="960"
        MinHeight="640"
        Width="1280"
        Height="800"
        Title="NbReader">
    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*,Auto">
        <Border Grid.RowSpan="3"
                Background="#111827"
                Padding="20">
            <StackPanel Spacing="18">
                <TextBlock Text="NbReader"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F9FAFB" />
                <TextBlock Text="本地漫画库"
                           FontSize="13"
                           Foreground="#93C5FD" />

                <StackPanel Spacing="8">
                    <TextBlock Text="模块"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E5E7EB">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="#1F2937"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="24,20"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="24">
            <Border IsVisible="{Binding IsCatalogSection}"
                    Background="Transparent">
                <views:CatalogView DataContext="{Binding Catalog}" />
            </Border>
            <Border IsVisible="{Binding IsImportSection}"
                    Background="Transparent">
                <views:ImportView DataContext="{Binding Import}" />
            </Border>
            <Border IsVisible="{Binding IsReaderSection}"
                    Background="Transparent">
                <views:ReaderView DataContext="{Binding Reader}" />
            </Border>
            <Border IsVisible="{Binding IsSearchSection}"
                    Background="Transparent">
                <views:SearchView DataContext="{Binding Search}" />
            </Border>

        </Grid>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding RuntimeSummary}"
                           Foreground="#475569" />
                <Expander Header="诊断信息"
                          IsExpanded="{Binding IsDiagnosticsExpanded, Mode=TwoWay}">
                    <TextBlock Text="{Binding DiagnosticsText}"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
